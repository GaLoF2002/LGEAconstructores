# MongoDB (Atlas free tier M0). Reemplaza usuario, password, cluster y dbname.
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — usar 64+ caracteres aleatorios en producción
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-al-menos-32-chars

# Servidor
PORT=5000
NODE_ENV=development

# Orígenes CORS permitidos (uno o varios separados por coma)
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (OPCIONAL — usar app password de Google, no la contraseña de la cuenta).
# Si se omiten, el server arranca igual; solo "Recuperar contraseña" no enviará correos.
GMAIL_USER=tu-correo@gmail.com
GMAIL_PASS=tu-app-password-de-16-chars

# Cloudinary
CLOUDINARY_CLOUD=tu-cloud-name
CLOUDINARY_KEY=tu-api-key
CLOUDINARY_SECRET=tu-api-secret

# API key para servicios externos (n8n: reporte semanal). Genera 48+ chars aleatorios.
# Si no se define, /api/reportes responde 503 (deshabilitado).
REPORT_API_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Bootstrap admin (solo necesario al ejecutar scripts/bootstrapAdmin.js)
# ADMIN_EMAIL=admin@tudominio.com
# ADMIN_PASSWORD=ContrasenaLargaYDificil!
# ADMIN_NAME=Administrador
# ADMIN_PHONE=0999999999